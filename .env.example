# Copy to Railway Variables on the app service (not the database service).
#
# Same-project Postgres (recommended — private network):
#   DATABASE_URL=${{Postgres.DATABASE_PRIVATE_URL}}
#
# Or public URL (works, but goes outside private mesh):
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
#
# Auth:
#   SESSION_SECRET=long-random-string
#
# Local file mode (default): leave DATABASE_URL empty.
#
# Optional:
#   DATABASE_SSL=true
#   PORT=3000
#   NODE_ENV=production
