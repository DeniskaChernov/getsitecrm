# =============================================================================
# GetSite OS — переменные окружения
# Скопируйте в .env локально или задайте в Railway → Variables.
# Значения (ключи) подставьте сами.
# =============================================================================

# --- Обязательные для продакшена ---

# Секрет подписи cookie-сессий (длинная случайная строка)
SESSION_SECRET=

# PostgreSQL connection string
# На Railway (рекомендуется приватная сеть):
#   DATABASE_URL=${{Postgres.DATABASE_PRIVATE_URL}}
# Или публичный URL:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=

# --- Опциональные (алиасы / совместимость) ---

# Если Railway отдаёт приватный URL отдельной переменной
DATABASE_PRIVATE_URL=

# Альтернативное имя (некоторые шаблоны Postgres)
POSTGRES_URL=

# SSL к БД: true | false  (в production по умолчанию включается)
DATABASE_SSL=

# Порт HTTP (на Railway задаётся автоматически)
PORT=

# production | development
NODE_ENV=
